# ─── PostgreSQL ──────────────────────────────────────
POSTGRES_DB=hanoi_lab
POSTGRES_USER=hanoi_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5434

# ─── pgAdmin ─────────────────────────────────────────
