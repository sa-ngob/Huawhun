# ─── HANOI LAB PRO — Production Environment ─────────────────────
# Copy this file to .env on the server and fill in real values.
# NEVER commit the actual .env file.

# ─── App ─────────────────────────────────────────────────────────
# Port that the app container publishes on the host
APP_PORT=8080

# Your domain (used for Traefik if enabled)
DOMAIN=your-domain.com

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_DB=hanoi_lab
POSTGRES_USER=hanoi_user
# REQUIRED: Set a strong password (min 20 chars recommended)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ─── Connection string (for any future API/backend) ───────────────
# Uses internal docker network hostname "db"
DATABASE_URL=postgresql://hanoi_user:CHANGE_ME_STRONG_PASSWORD_HERE@db:5432/hanoi_lab?sslmode=disable
